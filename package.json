{
  "name": "my-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:compile": "esbuild electron/main.ts --bundle --platform=node --outfile=dist-electron/main.cjs --format=cjs --external:electron",
    "electron": "npm run electron:compile && concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder --win"
  },
  "build": {
    "appId": "com.mygame.monsterclicker",
    "productName": "Monster Clicker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "esbuild": "^0.27.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
